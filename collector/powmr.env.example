# Copy to powmr.env and edit. Read by the systemd unit (EnvironmentFile) and
# auto-loaded by powmr_poll.py / powmr_daemon.py when run by hand.

# WiFi datalogger stick: LAN IP + serial number. The serial is on the sticker
# on the stick (also shown in the Solarman/PowMr app as "Device SN").
INVERTER_IP=192.168.1.50
LOGGER_SERIAL=1234567890
#INVERTER_PORT=8899

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
# Uncomment if your broker requires auth:
#MQTT_USER=solar
#MQTT_PASS=changeme
POLL_INTERVAL=10
BASE_TOPIC=solar/inverter
DISCOVERY_PREFIX=homeassistant
