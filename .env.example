# Copy to .env, set the two required values, then: docker compose up -d

# WiFi datalogger stick: LAN IP + serial number. The serial is on the sticker
# on the stick (also shown in the Solarman/PowMr app as "Device SN").
INVERTER_IP=192.168.1.50
LOGGER_SERIAL=1234567890

# Optional (defaults shown):
#INVERTER_PORT=8899
#POLL_INTERVAL=10
#BASE_TOPIC=solar/inverter
#DISCOVERY_PREFIX=homeassistant
#DASHBOARD_PORT=3001
# Using your own broker instead of the bundled mosquitto service:
#MQTT_HOST=192.168.1.10
#MQTT_PORT=1883

# Password-gate settings writes (PUT /api/settings). Leave unset for no gate
# (default; LAN-only use). Set it if you expose the dashboard publicly — see
# docs/exposure.md. Empty/unset = open writes, exactly as before.
#SETTINGS_PASSWORD=change-me

# Coarsen location coords (lat/lon) for unauthenticated GET /api/settings reads,
# so a public dashboard can't leak your house. Full precision is stored and
# served to the authenticated owner; reads are rounded to this many decimals.
# Default 2 (~1.1 km) — enough for sunrise/sunset night-shading. See
# docs/exposure.md. Range 0-7.
#LOCATION_PUBLIC_DECIMALS=2

# Auth-endpoint hardening (only relevant when SETTINGS_PASSWORD is set).
# Trust X-Forwarded-* so per-IP rate limiting keys on the real client IP.
# Enable ONLY behind a trusted proxy (e.g. the Cloudflare Tunnel connector);
# on a bare LAN it lets clients spoof their IP. Default off.
#TRUST_PROXY=true
# Cookie Secure flag: "auto" (derive from request scheme), "true", or "false".
#COOKIE_SECURE=auto
