# Copy to .env, set the two required values, then: docker compose up -d

# WiFi datalogger stick: LAN IP + serial number. The serial is on the sticker
# on the stick (also shown in the Solarman/PowMr app as "Device SN").
INVERTER_IP=192.168.1.50
LOGGER_SERIAL=1234567890

# Optional (defaults shown):
#INVERTER_PORT=8899
#POLL_INTERVAL=10
#BASE_TOPIC=solar/inverter
#DISCOVERY_PREFIX=homeassistant
#DASHBOARD_PORT=3001
# Using your own broker instead of the bundled mosquitto service:
#MQTT_HOST=192.168.1.10
#MQTT_PORT=1883

# Password-gate settings writes (PUT /api/settings). Leave unset for no gate
# (default; LAN-only use). Set it if you expose the dashboard publicly — see
# docs/exposure.md. Empty/unset = open writes, exactly as before.
#SETTINGS_PASSWORD=change-me
